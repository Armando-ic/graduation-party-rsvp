rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rsvps/{rsvpId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if false;
    }

    match /photos/{photoId} {
      allow create: if true;
      allow read: if true;
      allow delete: if request.auth != null;
      allow update: if false;
    }
  }
}
