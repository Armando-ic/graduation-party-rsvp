rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UID — only this account can read RSVPs and delete data
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'ZGc4z0ydjmccHf7mqiXYqmiqN522';
    }

    match /rsvps/{rsvpId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'status', 'plusOnes', 'message', 'createdAt'])
        && request.resource.data.keys().hasAll(['name', 'status', 'plusOnes', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 200
        && request.resource.data.status in ['coming', 'maybe', 'not_coming']
        && request.resource.data.plusOnes is list
        && request.resource.data.plusOnes.size() <= 1
        && (request.resource.data.plusOnes.size() == 0
            || (request.resource.data.plusOnes[0] is string
                && request.resource.data.plusOnes[0].size() > 0
                && request.resource.data.plusOnes[0].size() < 200))
        && request.resource.data.message is string
        && request.resource.data.message.size() < 2000;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /memories/{memoryId} {
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['storagePath', 'downloadURL', 'type', 'uploadedAt'])
        && request.resource.data.keys().hasAll(['storagePath', 'downloadURL', 'type', 'uploadedAt'])
        && request.resource.data.storagePath is string
        && request.resource.data.downloadURL is string
        && request.resource.data.downloadURL.matches('https://firebasestorage\\.googleapis\\.com/.*')
        && request.resource.data.type in ['image', 'video'];
      allow read: if true;
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /photos/{photoId} {
      allow create: if request.resource.data.keys().hasOnly(['uploaderName', 'storagePath', 'downloadURL', 'uploadedAt'])
        && request.resource.data.keys().hasAll(['uploaderName', 'storagePath', 'downloadURL', 'uploadedAt'])
        && request.resource.data.uploaderName is string
        && request.resource.data.uploaderName.size() < 200
        && request.resource.data.storagePath is string
        && request.resource.data.storagePath.matches('photos/[a-zA-Z0-9_-]+\\.jpg')
        && request.resource.data.downloadURL is string
        && request.resource.data.downloadURL.matches('https://firebasestorage\\.googleapis\\.com/.*');
      allow read: if true;
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
